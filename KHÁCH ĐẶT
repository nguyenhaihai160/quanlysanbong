<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<title>Quản Lý Sân Bóng</title>

<style>

body{
font-family:Arial;
background:#f4f4f4;
padding:20px;
}

h1{
text-align:center;
color:#27ae60;
}

.container{
display:flex;
flex-wrap:wrap;
gap:20px;
justify-content:center;
}

.box{
background:white;
padding:20px;
border-radius:10px;
width:400px;
box-shadow:0 0 10px rgba(0,0,0,0.2);
}

input,select,button{
width:100%;
padding:10px;
margin:6px 0;
font-size:16px;
}

button{
background:#27ae60;
color:white;
border:none;
cursor:pointer;
}

table{
width:100%;
border-collapse:collapse;
margin-top:10px;
}

th,td{
border:1px solid #ccc;
padding:8px;
text-align:center;
}

th{
background:#27ae60;
color:white;
}

</style>
</head>

<body>

<h1>⚽ HỆ THỐNG QUẢN LÝ SÂN BÓNG</h1>

<div class="container">

<!-- KHÁCH ĐẶT SÂN -->

<div class="box">

<h2>📱 Đặt Sân</h2>

<input type="date" id="date">

<select id="field">
<option>Sân 1</option>
<option>Sân 2</option>
<option>Sân 3</option>
</select>

<label>Giờ bắt đầu</label>
<input type="time" id="start">

<label>Giờ kết thúc</label>
<input type="time" id="end">

<input placeholder="Tên khách" id="name">

<input placeholder="Số điện thoại" id="phone">

<button onclick="book()">Đặt sân</button>

<p id="msg"></p>

</div>

<!-- TRANG QUẢN LÝ -->

<div class="box">

<h2>💻 Danh Sách Đặt Sân</h2>

<table>

<tr>
<th>Ngày</th>
<th>Sân</th>
<th>Bắt đầu</th>
<th>Kết thúc</th>
<th>Tên</th>
<th>SĐT</th>
</tr>

<tbody id="tableData"></tbody>

</table>

</div>

</div>

<script>

function book(){

let data={
date:date.value,
field:field.value,
start:start.value,
end:end.value,
name:name.value,
phone:phone.value
}

let bookings=JSON.parse(localStorage.getItem("bookings"))||[]

bookings.push(data)

localStorage.setItem("bookings",JSON.stringify(bookings))

msg.innerHTML="✅ Đặt sân thành công!"

loadTable()

}

function loadTable(){

let bookings=JSON.parse(localStorage.getItem("bookings"))||[]

tableData.innerHTML=""

bookings.forEach(b=>{

let row=document.createElement("tr")

row.innerHTML=`
<td>${b.date}</td>
<td>${b.field}</td>
<td>${b.start}</td>
<td>${b.end}</td>
<td>${b.name}</td>
<td>${b.phone}</td>
`

tableData.appendChild(row)

})

}

loadTable()

</script>

</body>
</html>
